name: "US services 专用覆写"
desc: "增加独立美国策略组并置顶规则"

# 1. 策略组配置
proxy-groups:
  - name: "US 专用"
    type: url-test
    url: "http://www.gstatic.com/generate_204"
    interval: 300
    # 自动引入所有订阅里的节点
    include-all: true
    # 过滤包含“美国”、“US”或“United States”的节点
    # (?i) 确保 us、Us、US 都能被识别
    filter: "(?i)美国|US|United States"

# 2. 规则配置（置顶）
prepend-rules:
  - DOMAIN-KEYWORD,notebooklm,US 专用
