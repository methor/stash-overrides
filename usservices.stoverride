name: "US services 专用覆写"
desc: "增加独立策略组并覆盖规则"

# 1. 创建一个新的策略组
proxy-groups:
  - name: US专用
    type: url-test
    # 下面这一行非常关键，它会自动引入你原订阅里的所有节点
    include-all: true
    # 你也可以指定只包含某些节点，比如：filter: "美国|US|United States"
    filter: "美国|US|United States"


# 2. 编写规则指向这个新策略组
rules:
  - DOMAIN-KEYWORD,notebooklm,US专用
